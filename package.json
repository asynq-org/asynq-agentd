{
  "name": "asynq-agentd-workspace",
  "version": "0.8.4",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "workspaces": [
    ".",
    "apps/*"
  ],
  "scripts": {
    "changeset": "changeset",
    "dev": "node apps/asynq-agentd/src/index.ts",
    "asynq-agentctl": "node apps/asynq-agentctl/src/index.ts",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "test": "node --test apps/asynq-agentd/src/db/storage.test.ts apps/asynq-agentd/src/adapters/codex-adapter.test.ts apps/asynq-agentd/src/adapters/claude-adapter.test.ts apps/asynq-agentd/src/http/server.test.ts apps/asynq-agentd/src/services/approval-policy-service.test.ts apps/asynq-agentd/src/services/dashboard-service.test.ts apps/asynq-agentd/src/services/event-stream-service.test.ts apps/asynq-agentd/src/services/process-monitor-service.test.ts apps/asynq-agentd/src/services/terminal-stream-service.test.ts apps/asynq-agentd/src/services/scheduler.test.ts apps/asynq-agentd/src/services/task-service.test.ts apps/asynq-agentd/src/services/config-service.test.ts apps/asynq-agentd/src/services/recent-work-service.test.ts apps/asynq-agentd/src/services/observed-resolution-service.test.ts apps/asynq-agentd/src/utils/terminal-spawn.test.ts apps/asynq-agentd/src/utils/websocket.test.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "qrcode": "^1.5.4",
    "yaml": "^2.8.2"
  }
}
